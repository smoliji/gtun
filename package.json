{
  "name": "@smoliji/gtun",
  "version": "0.1.0",
  "description": "Two-panel TUI to launch, stop and watch GCP tunnels (gcloud IAP, cloud-sql-proxy, custom commands) from a YAML config.",
  "type": "module",
  "bin": {
    "gtun": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smoliji/gtun.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "test": "tsx --test test/*.test.tsx",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "dependencies": {
    "ink": "^7.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
